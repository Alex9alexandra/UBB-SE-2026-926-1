@model ChatAndEvents.Web.Models.CreateDmViewModel

<div class="container mt-4" style="max-width: 500px;">
    <h2>New Direct Message</h2>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="mb-3">
        <label class="form-label">Search for a user</label>
        <input type="text" id="userSearch" class="form-control" placeholder="Type a username..." />
        <ul id="searchResults" class="list-group mt-1"></ul>
    </div>

    <form asp-action="CreateDm" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" id="targetUserId" name="TargetUserId" />
        <div id="selectedUser" class="alert alert-info d-none"></div>
        <button type="submit" id="submitBtn" class="btn btn-primary" disabled>Start Conversation</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>

<script>
    const searchInput = document.getElementById('userSearch');
    const resultsList = document.getElementById('searchResults');
    const targetUserIdInput = document.getElementById('targetUserId');
    const selectedUser = document.getElementById('selectedUser');
    const submitBtn = document.getElementById('submitBtn');

    searchInput.addEventListener('input', async () => {
        const query = searchInput.value.trim();
        if (query.length < 2) { resultsList.innerHTML = ''; return; }

        const response = await fetch(`/ConversationList/SearchUsers?query=${encodeURIComponent(query)}`);
        const users = await response.json();

        resultsList.innerHTML = users.map(u =>
            `<li class="list-group-item list-group-item-action" style="cursor:pointer"
                    onclick="selectUser('${u.id}', '${u.username}')">
                    ${u.username}
                </li>`
        ).join('');
    });

    function selectUser(id, username) {
        targetUserIdInput.value = id;
        selectedUser.textContent = `Selected: ${username}`;
        selectedUser.classList.remove('d-none');
        submitBtn.disabled = false;
        resultsList.innerHTML = '';
        searchInput.value = '';
    }
</script>