@model ChatAndEvents.Web.Models.CreateGroupViewModel

@{
    ViewData["Title"] = "Create group";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-1">New group</h2>
        <p class="text-muted mb-3">Give your group a name and add members.</p>

        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form asp-action="Create" method="post" id="create-group-form">
            @Html.AntiForgeryToken()

            @* Hidden field carries the comma-separated member IDs on submit *@
            <input type="hidden" id="selected-member-ids" name="SelectedMemberIds"
                   value="@Model.SelectedMemberIds" />

            <div class="mb-3">
                <label asp-for="GroupName" class="form-label"></label>
                <input asp-for="GroupName" class="form-control"
                       placeholder="Give your group a name" />
                <span asp-validation-for="GroupName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IconUrl" class="form-label">Group icon URL (optional)</label>
                <input asp-for="IconUrl" class="form-control"
                       placeholder="https://..." />
            </div>

            <hr class="my-3" />
            <h5>Add members</h5>

            <div class="mb-2">
                <input type="text" id="member-search" class="form-control"
                       placeholder="Search usernames..." autocomplete="off" />
            </div>

            <div id="search-results" class="list-group mb-3"></div>

            <div class="mb-3">
                <p class="text-muted small mb-1">Selected members</p>
                <div id="selected-members" class="d-flex flex-wrap gap-2">
                    @* Pre-populated on validation failure *@
                    @foreach (var member in Model.SelectedMembers)
                    {
                        <span class="badge bg-secondary d-flex align-items-center gap-1"
                              data-id="@member.Id">
                            @member.Username
                            <button type="button" class="btn-close btn-close-white btn-sm"
                                    aria-label="Remove" onclick="removeMember(this)"></button>
                        </span>
                    }
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
                <button type="submit" class="btn btn-primary">Create group</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const searchInput = document.getElementById('member-search');
        const searchResults = document.getElementById('search-results');
        const selectedContainer = document.getElementById('selected-members');
        const hiddenIds = document.getElementById('selected-member-ids');

        let searchTimeout = null;

        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            const query = searchInput.value.trim();

            if (!query) {
                searchResults.innerHTML = '';
                return;
            }

            searchTimeout = setTimeout(() => fetchUsers(query), 300);
        });

        async function fetchUsers(query) {
            const res = await fetch(`/Group/SearchUsers?query=${encodeURIComponent(query)}`);
            const users = await res.json();

            const selectedIds = getSelectedIds();
            searchResults.innerHTML = '';

            users
                .filter(u => !selectedIds.includes(u.id))
                .forEach(u => {
                    const item = document.createElement('button');
                    item.type = 'button';
                    item.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
                    item.innerHTML = `<span>${escapeHtml(u.username)}</span><span class="badge bg-primary">Add</span>`;
                    item.addEventListener('click', () => addMember(u));
                    searchResults.appendChild(item);
                });
        }

        function addMember(user) {
            if (getSelectedIds().includes(user.id)) return;

            const badge = document.createElement('span');
            badge.className = 'badge bg-secondary d-flex align-items-center gap-1';
            badge.dataset.id = user.id;
            badge.innerHTML = `${escapeHtml(user.username)}
                <button type="button" class="btn-close btn-close-white btn-sm"
                        aria-label="Remove" onclick="removeMember(this)"></button>`;
            selectedContainer.appendChild(badge);

            updateHiddenField();
            searchResults.querySelectorAll('button').forEach(btn => {
                if (btn.querySelector('span')?.textContent === user.username)
                    btn.remove();
            });
        }

        function removeMember(closeBtn) {
            closeBtn.closest('[data-id]').remove();
            updateHiddenField();
        }

        function getSelectedIds() {
            return [...selectedContainer.querySelectorAll('[data-id]')]
                .map(el => el.dataset.id);
        }

        function updateHiddenField() {
            hiddenIds.value = getSelectedIds().join(',');
        }

        function escapeHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }
    </script>
}