@model ChatAndEvents.Web.Models.MainWindowViewModel

@{
    ViewData["Title"] = "Unified App";
}

<div class="app-shell">
    <aside class="app-sidebar">
        <div class="app-brand">
            <div class="app-brand-title">Unified App</div>
            <div class="app-brand-user">@Model.CurrentUsername</div>
        </div>

        <nav class="app-nav">
            <div class="app-nav-group">SOCIAL</div>
            
            <a class="app-nav-link" asp-controller="ConversationList" asp-action="Index">Conversations</a>
            
            <a class="app-nav-link" asp-controller="FriendList" asp-action="Index">
                Friends 
                @if(Model.PendingFriendRequestsCount > 0) {
                    <span style="background:#dc3545; color:white; border-radius:50%; padding:2px 6px; font-size:12px; margin-left:5px;">@Model.PendingFriendRequestsCount</span>
                }
            </a>

            <a class="app-nav-link" asp-controller="Profile" asp-action="Index" asp-route-userId="@Model.CurrentUserId">Profile</a>

            <div class="app-nav-group">ACTIVITIES</div>
            
            <a class="app-nav-link" asp-controller="EventListing" asp-action="Index">Events</a>
            
            <a class="app-nav-link" asp-controller="MyEvents" asp-action="Index">My Events</a>
            
            <a class="app-nav-link" asp-controller="Reputation" asp-action="Index">Reputation &amp; Quests</a>
            
            <a class="app-nav-link" asp-controller="Notification" asp-action="Index">
                Notifications
                @if(Model.UnreadNotificationsCount > 0) {
                    <span style="background:#dc3545; color:white; border-radius:50%; padding:2px 6px; font-size:12px; margin-left:5px;">@Model.UnreadNotificationsCount</span>
                }
            </a>
        </nav>

        <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="app-logout" style="background:none; border:none; cursor:pointer;">Logout</button>
        </form>
    </aside>

    <section class="app-content">
        <div class="app-content-header">
            <h1>Welcome back, @Model.CurrentUsername</h1>
            <p>Choose a section from the sidebar to open the web version of the chat and events tools.</p>
        </div>

        <div class="quick-grid">
            <a class="quick-card" asp-controller="ConversationList" asp-action="Index">
                <span>Conversations</span>
                <strong>Open chat list</strong>
            </a>
            <a class="quick-card" asp-controller="EventListing" asp-action="Index">
                <span>Events</span>
                <strong>Browse public events</strong>
            </a>
            <a class="quick-card" asp-controller="MyEvents" asp-action="Index">
                <span>My Events</span>
                <strong>Manage your schedule</strong>
            </a>
            <a class="quick-card" asp-controller="FriendList" asp-action="Index">
                <span>Friends</span>
                <strong>Manage social links</strong>
            </a>
        </div>
    </section>
</div>