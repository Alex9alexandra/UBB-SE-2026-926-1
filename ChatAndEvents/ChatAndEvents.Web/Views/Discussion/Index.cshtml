@model ChatAndEvents.Web.Models.DiscussionViewModel

<div class="container mt-3">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @* ── Admin: Slow Mode Bar ── *@
    @if (Model.IsEventAdmin)
    {
        <div class="card mb-3">
            <div class="card-body py-2 d-flex align-items-center gap-3 flex-wrap">
                <span class="text-muted small">⏱ @Model.SlowModeStatusText</span>
                <form asp-action="SetSlowMode" method="post" class="d-flex gap-2 align-items-center">
                    <input type="hidden" name="eventId" value="@Model.EventId" />
                    <input type="hidden" name="isAdmin" value="true" />
                    <input type="number" name="seconds" class="form-control form-control-sm"
                           style="width:90px" placeholder="Seconds" min="1" max="3600" />
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Enable</button>
                </form>
                @if (Model.IsSlowModeActive)
                {
                    <form asp-action="SetSlowMode" method="post" class="d-inline">
                        <input type="hidden" name="eventId" value="@Model.EventId" />
                        <input type="hidden" name="isAdmin" value="true" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Turn Off</button>
                    </form>
                }
            </div>
        </div>
    }

    @* ── Messages ── *@
    <div class="d-flex flex-column gap-2 mb-3" style="max-height:60vh; overflow-y:auto;" id="messageList">

        @if (Model.Messages.Count == 0)
        {
            <p class="text-muted text-center mt-4">No messages yet. Start the conversation!</p>
        }

        @foreach (var item in Model.Messages)
        {
            <div class="card">
                <div class="card-body py-2">

                    @* Reply reference *@
                    @if (item.Message.ReplyTo != null)
                    {
                        <div class="border-start border-primary ps-2 mb-2 text-muted small">
                            <strong>@item.Message.ReplyTo.Author?.Name</strong><br />
                            <span>@(item.Message.ReplyTo.Message ?? "[deleted message]")</span>
                        </div>
                    }

                    @* Author + date *@
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <strong>@(item.Message.Author?.Name ?? "Unknown")</strong>
                        <span class="text-muted small">@item.Message.DateCreated.ToString("MMM dd, yyyy HH:mm")</span>
                        @if (item.Message.IsEdited)
                        {
                            <span class="badge bg-secondary">edited</span>
                        }
                    </div>

                    @* Message text *@
                    @if (!string.IsNullOrWhiteSpace(item.Message.Message))
                    {
                        <p class="mb-1">@item.Message.Message</p>
                    }

                    @* Media *@
                    @if (!string.IsNullOrWhiteSpace(item.Message.MediaPath))
                    {
                        <div class="mb-1">
                            <img src="@item.Message.MediaPath" class="img-fluid rounded"
                                 style="max-height:250px" alt="attachment" />
                        </div>
                    }

                    @* Reactions *@
                    @if (item.ReactionGroups.Count > 0)
                    {
                        <div class="d-flex gap-1 flex-wrap mb-2">
                            @foreach (var r in item.ReactionGroups)
                            {
                                <span class="badge border @(r.CurrentUserReacted ? "border-primary text-primary" : "border-secondary text-secondary")">
                                    @r.Emoji @r.Count
                                </span>
                            }
                        </div>
                    }

                    @* Actions *@
                    <div class="d-flex gap-2 flex-wrap mt-1">

                        @* Reply *@
                        <button class="btn btn-sm btn-outline-secondary"
                                onclick="setReply(@item.Message.Id, '@(item.Message.Author?.Name ?? "")', '@((item.Message.Message ?? "").Replace("'", "\\'"))')">
                            ↩ Reply
                        </button>

                        @* React *@
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                    data-bs-toggle="dropdown">
                                React
                            </button>
                            <ul class="dropdown-menu">
                                @foreach (var emoji in new[] { "👍", "❤️", "😂", "😮", "😢", "🔥" })
                                {
                                    <li>
                                        @if (item.CurrentUserEmoji == emoji)
                                        {
                                            <form asp-action="RemoveReaction" method="post" class="d-inline">
                                                <input type="hidden" name="messageId" value="@item.Message.Id" />
                                                <input type="hidden" name="eventId" value="@Model.EventId" />
                                                <input type="hidden" name="isAdmin" value="@Model.IsEventAdmin" />
                                                <button type="submit" class="dropdown-item">@emoji ✓</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="React" method="post" class="d-inline">
                                                <input type="hidden" name="messageId" value="@item.Message.Id" />
                                                <input type="hidden" name="eventId" value="@Model.EventId" />
                                                <input type="hidden" name="emoji" value="@emoji" />
                                                <input type="hidden" name="isAdmin" value="@Model.IsEventAdmin" />
                                                <button type="submit" class="dropdown-item">@emoji</button>
                                            </form>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>

                        @* Delete *@
                        @if (item.Message.CanDelete)
                        {
                            <form asp-action="Delete" method="post"
                                  onsubmit="return confirm('Delete this message?')">
                                <input type="hidden" name="messageId" value="@item.Message.Id" />
                                <input type="hidden" name="eventId" value="@Model.EventId" />
                                <input type="hidden" name="isAdmin" value="@Model.IsEventAdmin" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">🗑 Delete</button>
                            </form>
                        }

                        @* Mute / Unmute *@
                        @if (item.ShowMuteButton)
                        {
                            <button class="btn btn-sm btn-outline-warning"
                                    onclick="showMuteModal('@item.Message.Author!.UserId', '@item.Message.Author.Name')">
                                Mute
                            </button>
                            <form asp-action="Unmute" method="post" class="d-inline">
                                <input type="hidden" name="eventId" value="@Model.EventId" />
                                <input type="hidden" name="targetUserId" value="@item.Message.Author!.UserId" />
                                <input type="hidden" name="isAdmin" value="@Model.IsEventAdmin" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Unmute</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── Mute status ── *@
    @if (Model.IsMuted)
    {
        <div class="alert alert-warning">
            🔇 @(Model.MuteRemainingText ?? "You are muted.")
        </div>
    }

    @* ── Reply preview bar ── *@
    <div id="replyBar" class="border-start border-primary ps-2 mb-2 small text-muted d-none">
        Replying to <strong id="replyAuthor"></strong>:
        <em id="replyPreview"></em>
        <button class="btn btn-sm" onclick="clearReply()">✕</button>
    </div>

    @* ── Send form ── *@
    @if (!Model.IsMuted)
    {
        <form asp-action="Send" method="post" class="d-flex gap-2 align-items-end">
            <input type="hidden" name="eventId" value="@Model.EventId" />
            <input type="hidden" name="isAdmin" value="@Model.IsEventAdmin" />
            <input type="hidden" name="replyToId" id="replyToId" value="" />
            <textarea name="newMessage" class="form-control" rows="2"
                      placeholder="Type a message..."></textarea>
            <button type="submit" class="btn btn-primary">Send</button>
        </form>
    }
</div>

@* ── Mute Modal ── *@
<div class="modal fade" id="muteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Mute <span id="muteTargetName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Duration</label>
                    <select class="form-select" id="muteDurationSelect"
                            onchange="toggleCustomMute(this.value)">
                        <option value="1 hour">1 hour</option>
                        <option value="24 hours">24 hours</option>
                        <option value="Custom">Custom</option>
                        <option value="Permanent">Permanent</option>
                    </select>
                </div>
                <div id="customMutePanel" class="d-none">
                    <div class="mb-2">
                        <label class="form-label">Hours</label>
                        <input type="number" id="muteHours" class="form-control"
                               min="0" max="720" value="0" />
                    </div>
                    <div>
                        <label class="form-label">Minutes</label>
                        <input type="number" id="muteMinutes" class="form-control"
                               min="0" max="59" value="30" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" onclick="submitMute()">Mute</button>
            </div>
        </div>
    </div>
</div>

@* Hidden mute form — raw values posted to controller, no computation here *@
<form id="muteForm" asp-action="Mute" method="post" class="d-none">
    <input type="hidden" name="eventId" value="@Model.EventId" />
    <input type="hidden" name="isAdmin" value="@Model.IsEventAdmin" />
    <input type="hidden" name="targetUserId" id="muteFormTargetUserId" />
    <input type="hidden" name="duration" id="muteFormDuration" />
    <input type="hidden" name="customHours" id="muteFormHours" />
    <input type="hidden" name="customMinutes" id="muteFormMinutes" />
</form>

<script>
    function setReply(id, author, preview) {
        document.getElementById('replyToId').value = id;
        document.getElementById('replyAuthor').textContent = author;
        document.getElementById('replyPreview').textContent = preview;
        document.getElementById('replyBar').classList.remove('d-none');
    }

    function clearReply() {
        document.getElementById('replyToId').value = '';
        document.getElementById('replyBar').classList.add('d-none');
    }

    function showMuteModal(userId, name) {
        document.getElementById('muteFormTargetUserId').value = userId;
        document.getElementById('muteTargetName').textContent = name;
        new bootstrap.Modal(document.getElementById('muteModal')).show();
    }

    function toggleCustomMute(value) {
        document.getElementById('customMutePanel')
            .classList.toggle('d-none', value !== 'Custom');
    }

    function submitMute() {
        document.getElementById('muteFormDuration').value =
            document.getElementById('muteDurationSelect').value;
        document.getElementById('muteFormHours').value =
            document.getElementById('muteHours').value;
        document.getElementById('muteFormMinutes').value =
            document.getElementById('muteMinutes').value;

        bootstrap.Modal.getInstance(document.getElementById('muteModal')).hide();
        document.getElementById('muteForm').submit();
    }

    const list = document.getElementById('messageList');
    if (list) list.scrollTop = list.scrollHeight;
</script>