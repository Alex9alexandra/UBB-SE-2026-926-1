@model Events_GSS.Data.Models.Memory

<h1>Add New Memory</h1>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="EventId" />

    <div class="form-group mb-3">
        <label>Description</label>
        <textarea asp-for="Text" class="form-control" rows="3"></textarea>
    </div>

    <div class="form-group mb-3">
        <label>Photo URL (Optional)</label>
        <input asp-for="PhotoPath" class="form-control" placeholder="https://..." />
    </div>

    <button type="submit" class="btn btn-success">Save Memory</button>
    <a asp-action="Index" asp-route-eventId="@Model.EventId" class="btn btn-secondary">Cancel</a>
</form>