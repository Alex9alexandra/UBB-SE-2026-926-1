@model ChatAndEvents.Web.Models.MemoryViewModel

@{
    ViewData["Title"] = "Memories - " + Model.EventName;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Memories for @Model.EventName</h1>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!Model.ShowGallery)
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            <a asp-action="Index"
               asp-route-eventId="@Model.EventId"
               asp-route-showOnlyMine="@(!Model.ShowOnlyMine)"
               asp-route-sortAscending="@Model.SortAscending"
               class="btn btn-sm @(Model.ShowOnlyMine ? "btn-primary" : "btn-outline-primary")">
                My Memories
            </a>
            <a asp-action="Index"
               asp-route-eventId="@Model.EventId"
               asp-route-showOnlyMine="@Model.ShowOnlyMine"
               asp-route-sortAscending="true"
               class="btn btn-sm btn-outline-secondary">Date ↑</a>
            <a asp-action="Index"
               asp-route-eventId="@Model.EventId"
               asp-route-showOnlyMine="@Model.ShowOnlyMine"
               asp-route-sortAscending="false"
               class="btn btn-sm btn-outline-secondary">Date ↓</a>
            <a asp-action="Index"
               asp-route-eventId="@Model.EventId"
               asp-route-showGallery="true"
               class="btn btn-sm btn-outline-secondary">📷 Gallery</a>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <form asp-action="Add" method="post">
                    <input type="hidden" name="eventId" value="@Model.EventId" />
                    <input type="hidden" name="showOnlyMine" value="@Model.ShowOnlyMine" />
                    <input type="hidden" name="sortAscending" value="@Model.SortAscending" />
                    <div class="mb-2">
                        <textarea name="text" class="form-control" rows="2"
                                  placeholder="Share a memory..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">+ Add Memory</button>
                </form>
            </div>
        </div>

        @if (Model.Memories == null || Model.Memories.Count == 0)
        {
            <div class="alert alert-info">
                No memories have been shared for this event yet. Be the first to share one!
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in Model.Memories)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            
                            @if (!string.IsNullOrWhiteSpace(item.Memory.PhotoPath))
                            {
                                <img src="@item.Memory.PhotoPath" class="card-img-top" alt="Memory photo"
                                     style="height: 200px; object-fit: cover;">
                            }

                            <div class="card-body d-flex flex-column justify-content-between">
                                
                                @if (!string.IsNullOrWhiteSpace(item.Memory.Text))
                                {
                                    <p class="card-text">@item.Memory.Text</p>
                                }

                                <div class="mt-auto">
                                    <hr />
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <small class="text-muted">
                                                By <strong>@(item.Memory.Author?.Name ?? "Anonymous")</strong>
                                            </small><br />
                                            <small class="text-muted">
                                                @item.Memory.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                            </small>
                                        </div>

                                        <div class="d-flex gap-2 align-items-center">
                                            <span class="badge bg-light text-dark">@item.Memory.LikesCount ♥</span>

                                            @if (item.CanLike)
                                            {
                                                <form asp-action="ToggleLike" method="post" class="d-inline">
                                                    <input type="hidden" name="memoryId" value="@item.Memory.MemoryId" />
                                                    <input type="hidden" name="eventId" value="@Model.EventId" />
                                                    <input type="hidden" name="showOnlyMine" value="@Model.ShowOnlyMine" />
                                                    <input type="hidden" name="sortAscending" value="@Model.SortAscending" />
                                                    <button type="submit"
                                                            class="btn btn-sm @(item.Memory.IsLikedByCurrentUser ? "btn-danger" : "btn-outline-danger")">
                                                        @(item.Memory.IsLikedByCurrentUser ? "♥ Unlike" : "♥ Like")
                                                    </button>
                                                </form>
                                            }

                                            @if (item.CanDelete)
                                            {
                                                <form asp-action="Delete" method="post" class="d-inline"
                                                      onsubmit="return confirm('Delete this memory?')">
                                                    <input type="hidden" name="memoryId" value="@item.Memory.MemoryId" />
                                                    <input type="hidden" name="eventId" value="@Model.EventId" />
                                                    <input type="hidden" name="showOnlyMine" value="@Model.ShowOnlyMine" />
                                                    <input type="hidden" name="sortAscending" value="@Model.SortAscending" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">🗑</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="mb-3 d-flex align-items-center gap-3">
            <h5 class="mb-0">Photo Gallery</h5>
            <a asp-action="Index"
               asp-route-eventId="@Model.EventId"
               class="btn btn-sm btn-outline-secondary">← Back to Memories</a>
        </div>

        @if (Model.GalleryPhotos == null || Model.GalleryPhotos.Count == 0)
        {
            <p class="text-muted">No photos yet.</p>
        }
        else
        {
            <div class="row g-2">
                @foreach (var photo in Model.GalleryPhotos)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <img src="@photo" class="img-fluid rounded"
                             style="height:150px; width:100%; object-fit:cover" alt="gallery photo" />
                    </div>
                }
            </div>
        }
    }
</div>