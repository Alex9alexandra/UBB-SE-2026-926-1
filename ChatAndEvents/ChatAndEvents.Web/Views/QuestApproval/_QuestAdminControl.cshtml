@model ChatAndEvents.Web.Models.QuestAdminViewModel

<div class="card h-100">
    <div class="card-body p-4">
        <h2 class="h4 mb-1">Quest Admin</h2>
        <p class="text-muted mb-4">Create, attach, select, and delete quests for this event.</p>

        <div class="row g-4">
            <div class="col-12">
                <div class="quest-admin-panel">
                    <h3 class="h5">Add Custom Quest</h3>

                    <form asp-controller="QuestAdmin" asp-action="AddCustom" method="post" class="row g-3">
                        <input type="hidden" asp-for="EventId" />
                        <input type="hidden" asp-for="SelectedQuestId" />

                        <div class="col-12">
                            <label class="form-label" asp-for="NewQuestName">Name</label>
                            <input class="form-control" asp-for="NewQuestName" />
                        </div>

                        <div class="col-12">
                            <label class="form-label" asp-for="NewQuestDescription">Description</label>
                            <textarea class="form-control" asp-for="NewQuestDescription" rows="3"></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" asp-for="NewQuestDifficulty">Difficulty</label>
                            <select class="form-select" asp-for="NewQuestDifficulty">
                                @for (var difficulty = 1; difficulty <= 5; difficulty++)
                                {
                                    <option value="@difficulty">@difficulty</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" asp-for="SelectedPrerequisiteQuestId">Prerequisite</label>
                            <select class="form-select" asp-for="SelectedPrerequisiteQuestId">
                                <option value="">None</option>
                                @foreach (var quest in Model.Quests)
                                {
                                    <option value="@quest.Id">@quest.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">Add Custom Quest</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-12">
                <div class="quest-admin-panel">
                    <h3 class="h5">Add Preset Quest</h3>

                    <form asp-controller="QuestAdmin" asp-action="AddPreset" method="post" class="row g-3">
                        <input type="hidden" asp-for="EventId" />
                        <input type="hidden" asp-for="SelectedQuestId" />

                        <div class="col-12">
                            <label class="form-label" asp-for="SelectedPresetQuestId">Preset Quest</label>
                            <select class="form-select" asp-for="SelectedPresetQuestId">
                                <option value="">Select a preset quest</option>
                                @foreach (var quest in Model.PresetQuests)
                                {
                                    <option value="@quest.Id">@quest.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-outline-primary">Add Preset Quest</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-12">
                <div class="quest-admin-panel">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <h3 class="h5 mb-0">Event Quests</h3>
                        <span class="badge text-bg-secondary">@Model.Quests.Count</span>
                    </div>

                    @if (Model.Quests.Count == 0)
                    {
                        <div class="alert alert-info mb-0">No quests have been added to this event yet.</div>
                    }
                    else
                    {
                        <div class="quest-admin-list">
                            @foreach (var quest in Model.Quests)
                            {
                                var isSelected = Model.SelectedQuestId == quest.Id;

                                <div class="quest-admin-item @(isSelected ? "selected" : string.Empty)">
                                    <div>
                                        <div class="fw-semibold">@quest.Name</div>
                                        <div class="text-muted small">@quest.Description</div>
                                        <div class="small mt-2">
                                            Difficulty: @quest.Difficulty / 5
                                            @if (quest.PrerequisiteQuest != null)
                                            {
                                                <span class="ms-2">Prerequisite: @quest.PrerequisiteQuest.Name</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">
                                        <form asp-controller="QuestApproval" asp-action="SelectQuest" method="post">
                                            <input type="hidden" name="eventId" value="@Model.EventId" />
                                            <input type="hidden" name="selectedQuestId" value="@quest.Id" />
                                            <button type="submit" class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-primary")">
                                                @(isSelected ? "Selected" : "Review")
                                            </button>
                                        </form>

                                        <form asp-controller="QuestAdmin" asp-action="Delete" method="post">
                                            <input type="hidden" name="eventId" value="@Model.EventId" />
                                            <input type="hidden" name="questId" value="@quest.Id" />
                                            <input type="hidden" name="selectedQuestId" value="@Model.SelectedQuestId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
