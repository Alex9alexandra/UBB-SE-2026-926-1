@model ChatAndEvents.Data.EventsData.Models.Event

@{
    ViewData["Title"] = Model.Name;
    Layout = null;
}

<div style="padding: 40px; background: #17153B; min-height: 100vh; color: white; font-family: sans-serif;">
    <div style="max-width: 800px; margin: 0 auto; background: #2E236C; padding: 40px; border-radius: 15px; border: 1px solid #433D8B;">
        
        <a asp-action="Index" style="color: #C8ACD6; text-decoration: none; font-size: 14px;">← Back to List</a>
        
        <h1 style="font-size: 36px; margin-top: 20px; margin-bottom: 10px;">@Model.Name</h1>
        
        <div style="display: flex; gap: 20px; margin-bottom: 30px; opacity: 0.8;">
            <span>📅 @Model.StartDateTime.ToString("f")</span>
            <span>📍 @Model.Location</span>
        </div>

        <div style="line-height: 1.6; font-size: 18px; margin-bottom: 40px;">
            <p>@Model.Description</p>
        </div>

       
    </div>
</div>