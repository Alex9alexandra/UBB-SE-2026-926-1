@model ChatAndEvents.Web.Models.EventListingViewModel

@{
    ViewData["Title"] = "Events";
}

<div class="events-page">
    <div class="page-title-row">
        <div>
            <h1>Events</h1>
            <p class="text-muted mb-0">Public active events available in the app.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">+ Create Event</a>
    </div>

    <form asp-action="Index" method="get" class="filter-bar">
        <input class="form-control" name="searchQuery" value="@Model.SearchQuery" placeholder="Search by title" />
        <input class="form-control" name="locationFilter" value="@Model.LocationFilter" placeholder="Filter by location" />
        <button class="btn btn-outline-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Events.Count == 0)
    {
        <div class="alert alert-info">No events found.</div>
    }
    else
    {
        <div class="event-list">
            @foreach (var item in Model.Events)
            {
                <a class="event-list-item" asp-controller="EventDetail" asp-action="Index" asp-route-eventId="@item.EventId">
                    <div>
                        <h2>@item.Name</h2>
                        <div class="event-meta">
                            <span>@item.Location</span>
                            <span>@item.StartDateTime.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p>@item.Description</p>
                        }
                    </div>
                    <div class="event-count">
                        <strong>@item.EnrolledCount</strong>
                        <span>enrolled</span>
                    </div>
                </a>
            }
        </div>
    }
</div>
