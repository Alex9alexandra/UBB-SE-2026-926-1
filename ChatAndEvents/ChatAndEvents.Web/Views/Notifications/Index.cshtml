@model ChatAndEvents.Web.Models.NotificationsViewModel

@{
    ViewData["Title"] = "Notifications";
}

<div class="px-2 py-3">
    <h2 class="mb-4">Notifications</h2>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.IsEmpty)
    {
        <p class="text-muted text-center py-5">No notifications yet.</p>
    }
    else
    {
        @foreach (var n in Model.Notifications)
        {
            <div class="card mb-2">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold mb-1">@n.Title</div>
                            <div class="text-muted mb-1">@n.Description</div>
                            <div class="text-muted" style="font-size:0.8rem">@n.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                        <form method="post" asp-action="Delete" class="flex-shrink-0 ms-3">
                            <input type="hidden" name="notificationId" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>